{
  "auth": {
    "listen": "/api/auth",

    "plugin": {
      "local": "workos"
    }
  },

  "routes": [
    {
      "listen": "/api/local/metrics/",

      "plugin": {
        "local": "local-metrics"
      }
    },

    {
      "listen": "/api/external/metrics/",

      "plugin": {
        "proxy": [
          "https://metrics-primary.example.com/v1/metrics",
          "https://metrics-secondary.example.com/v1/metrics"
        ]
      }
    },

    {
      "listen": "/api/external/maps/",

      "plugin": {
        "proxy": [
          "https://maps-a.example.com/api/maps",
          "https://maps-b.example.com/api/maps",
          "https://maps-c.example.com/api/maps"
        ]
      }
    }
  ]
}
