# WorkOS User Management (AuthKit) — https://dashboard.workos.com
# Required when the gateway "auth" uses plugin "workos" (default) or it is omitted (defaults to in-process WorkOS at /api/auth/).
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must match a Redirect URI configured for this application (e.g. AuthKit callback).
WORKOS_REDIRECT_URI=https://localhost:8443/api/auth/callback

# Dev-only: auth plugin "allow" (JSON: "plugin": { "local": "allow" }) — bypasses real IdP; issues HS256 JWTs that always validate. Never enable in production with real data.
# DAFUQ_ALLOW_INSECURE_AUTH=true
# DAFUQ_ALLOW_JWT_SECRET=change-me-in-ci
# DAFUQ_ALLOW_SUBJECT=test-user

# Linux: auth plugin "pam" (JSON: "plugin": { "local": "pam" }) — PAM password auth, then signed JWTs. Requires CGO and libc. Set a strong HMAC secret.
# DAFUQ_PAM_JWT_SECRET=change-me
# DAFUQ_PAM_SERVICE=login

# When DAFUQ_API_PROXY_CONFIG_FILE sets "auth" to use "backends" (proxy to an external auth BFF, e.g. Auth0), these validate access tokens for /api/v1/ and data gateway routes:
# DAFUQ_JWKS_URL=
# DAFUQ_JWT_ISSUER=
# DAFUQ_JWT_AUDIENCE=

# Optional: issuer claim for JWT validation (default https://api.workos.com — same for all regions)
# DAFUQ_WORKOS_JWT_ISSUER=https://api.workos.com

# Browser redirect target after GET /api/auth/callback when Accept does not prefer JSON (path or full URL).
# Tokens are appended to the fragment: #access_token=...&refresh_token=...
# DAFUQ_POST_LOGIN_REDIRECT=/

# Optional: listen address (defaults :8443 with TLS, :8080 without)
# DAFUQ_ADDR=:8080

# HTTP server (timeouts use Go duration strings: 60s, 2m, etc.)
# DAFUQ_HTTP_READ_HEADER_TIMEOUT=10s
# DAFUQ_HTTP_READ_TIMEOUT=1m
# DAFUQ_HTTP_WRITE_TIMEOUT=1m
# DAFUQ_HTTP_IDLE_TIMEOUT=2m
# DAFUQ_HTTP_SHUTDOWN_TIMEOUT=30s
# Max bytes read for BFF / gateway HTTP proxy request bodies to upstreams (0 = 10 MiB default)
# DAFUQ_PROXY_MAX_BODY_BYTES=0

# TLS — when both are set, the server uses HTTPS
# DAFUQ_TLS_CERT_FILE=./certs/localhost.pem
# DAFUQ_TLS_KEY_FILE=./certs/localhost-key.pem

# Vite build output (relative to backend/ when you run the binary from backend/)
DAFUQ_STATIC_DIR=../dist

# Optional: JSON for auth (workos in-process or backends proxy) + data gateway routes — see api-proxy-routes.example.json
# DAFUQ_API_PROXY_CONFIG_FILE=./api-proxy-routes.json

# Per-user dashboard JSON files (default: data/dashboards)
# DAFUQ_DASHBOARD_DATA_DIR=data/dashboards

# When using HTTP locally, cookies must not be Secure=false; set explicitly if needed:
# DAFUQ_COOKIE_SECURE=false
